			"esbuild@<0.28.1": ">=0.28.1",
			"cookie@<0.7.0": "^0.7.0"
		}
	},
	"dependencies": {
		"@cropwatchdevelopment/cwui": "0.1.107",
		"@supabase/supabase-js": "^2.108.2"
	}
